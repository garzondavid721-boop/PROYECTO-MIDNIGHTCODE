# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:CAMBIA_ESTO@db:3306/midnightcode
DB_ROOT_PASSWORD=CAMBIA_ESTO
DB_NAME=midnightcode

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://tu-dominio.com

# ─── Seed admin (solo para el primer deploy, cambiar después) ─────────────────
ADMIN_EMAIL=admin@tu-empresa.com
ADMIN_PASSWORD=CAMBIA_ESTO_POR_PASSWORD_SEGURO
ADMIN_DOC=1001
